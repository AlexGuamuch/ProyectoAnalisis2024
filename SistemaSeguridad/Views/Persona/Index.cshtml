@model IEnumerable<Persona>

@{
    ViewData["Title"] = "Lista de Personas";
}

<h1>Lista de Personas</h1>

<p>
    <a asp-action="Crear" class="btn btn-primary">Crear Nueva Persona</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Fecha de Nacimiento</th>
            <th>Género</th>
            <th>Dirección</th>
            <th>Teléfono</th>
            <th>Correo Electrónico</th>
            <th>Estado Civil</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var persona in Model)
        {
            <tr>
                <td>@persona.IdPersona</td>
                <td>@persona.Nombre</td>
                <td>@persona.Apellido</td>
                <td>@persona.FechaNacimiento.ToShortDateString()</td>
                <td>@persona.IdGenero</td>
                <td>@persona.Direccion</td>
                <td>@persona.Telefono</td>
                <td>@persona.CorreoElectronico</td>
                <td>@persona.IdEstadoCivil</td>
                <td>
                    <a asp-action="Editar" asp-route-idPersona="@persona.IdPersona" class="btn btn-warning">Editar</a>
                    <a asp-action="Borrar" asp-route-idPersona="@persona.IdPersona" class="btn btn-danger">Borrar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="ExportarCSV" class="btn btn-secondary">Exportar a CSV</a>

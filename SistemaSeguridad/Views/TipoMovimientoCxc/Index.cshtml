@model IEnumerable<SistemaSeguridad.Models.TipoMovimientoCxc>

@{
    ViewData["Title"] = "Tipos de Movimiento CXC";
}

<!-- Contenedor principal -->
<div class="custom-background p-4">

    <!-- Título -->
    <h1 class="mb-4 text-black">@ViewData["Title"]</h1>

    <!-- Tabla de tipos de movimiento -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered bg-white">
            <thead class="thead-dark">
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Operación Cuenta Corriente</th>
                    <th>Fecha Creación</th>
                    <th>Usuario Creación</th>
                    <th>Fecha Modificación</th>
                    <th>Usuario Modificación</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tipoMovimiento in Model)
                {
                    <tr>
                        <td>@tipoMovimiento.IdTipoMovimientoCxc</td>
                        <td>@tipoMovimiento.Nombre</td>
                        <td>@tipoMovimiento.OperacionCuentaCorriente</td>
                        <td>@tipoMovimiento.FechaCreacion.ToString("yyyy-MM-dd")</td>
                        <td>@tipoMovimiento.UsuarioCreacion</td>
                        <td>@tipoMovimiento.FechaModificacion?.ToString("yyyy-MM-dd")</td>
                        <td>@tipoMovimiento.UsuarioModificacion</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Estilos CSS -->
<style>
    .custom-background {
        background-color: #ffffff; /* Color de fondo blanco */
        border-radius: 10px; /* Bordes redondeados */
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Sombra sutil */
    }

    .bg-white {
        background-color: #ffffff; /* Fondo blanco para la tabla */
    }

    .text-black {
        color: black; /* Texto negro para títulos */
    }

    .thead-dark {
        background-color: #ffffff; /* Fondo claro para el encabezado de la tabla */
        color: black; /* Texto negro para el encabezado de la tabla */
    }

    .table th {
        text-align: center; /* Alinear el texto de los encabezados al centro */
    }

    .table td {
        font-size: 0.875rem; /* Tamaño de fuente más pequeño */
        padding: 0.5rem; /* Relleno más pequeño */
    }
</style>

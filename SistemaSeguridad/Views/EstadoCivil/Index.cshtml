@model IEnumerable<EstadoCivil>

@{
    ViewData["Title"] = "Lista de Estados Civiles";
}

<!-- Contenedor principal -->
<div class="custom-background p-4">

    <!-- Títulos -->
    <h1 class="mb-4 text-black">@ViewData["Title"]</h1>

    <!-- Tabla -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered bg-white">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Nombre</th>
                    <th scope="col">Fecha de Creación</th>
                    <th scope="col">Usuario de Creación</th>
                    <th scope="col">Fecha de Modificación</th>
                    <th scope="col">Usuario de Modificación</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var estado in Model)
                {
                    <tr>
                        <td>@estado.IdEstadoCivil</td>
                        <td>@estado.Nombre</td>
                        <td>@estado.FechaCreacion.ToString("g")</td> <!-- Formato de fecha general -->
                        <td>@estado.UsuarioCreacion</td>
                        <td>@estado.FechaModificacion?.ToString("g")</td> <!-- Usar null-conditional para evitar excepciones -->
                        <td>@estado.UsuarioModificacion</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Estilos CSS -->
<style>
    .custom-background {
        background-color: #ffffff; /* Color de fondo oscuro */
        border-radius: 10px; /* Bordes redondeados */
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Sombra sutil */
    }

    .bg-white {
        background-color: #ffffff; /* Fondo blanco para la tabla */
    }

    .text-white {
        color: #ffffff; /* Texto blanco para contrastar con el fondo oscuro */
    }

    .thead-dark {
        background-color: #ffffff; /* Fondo oscuro para el encabezado de la tabla */
        color: black; /* Texto blanco para el encabezado de la tabla */
    }

    .table th {
        text-align: center; /* Alinear el texto de los encabezados al centro */
    }

    .table td {
        font-size: 0.875rem; /* Tamaño de fuente más pequeño */
        padding: 0.5rem; /* Relleno más pequeño */
    }
</style>

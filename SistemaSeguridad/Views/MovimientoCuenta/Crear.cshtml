@model MovimientoCuentum

@{
    ViewData["Title"] = "Registrar Movimiento";
}

<h1>Registrar Nuevo Movimiento</h1>

<form asp-action="Crear">
    <div class="form-group">
        <label asp-for="IdSaldoCuenta"></label>
        <input asp-for="IdSaldoCuenta" class="form-control" />
        <span asp-validation-for="IdSaldoCuenta" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="IdTipoMovimientoCxc"></label>
        <input asp-for="IdTipoMovimientoCxc" class="form-control" />
        <span asp-validation-for="IdTipoMovimientoCxc" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="FechaMovimiento"></label>
        <input asp-for="FechaMovimiento" type="date" class="form-control" />
        <span asp-validation-for="FechaMovimiento" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ValorMovimiento"></label>
        <input asp-for="ValorMovimiento" class="form-control" />
        <span asp-validation-for="ValorMovimiento" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ValorMovimientoPagado"></label>
        <input asp-for="ValorMovimientoPagado" class="form-control" />
        <span asp-validation-for="ValorMovimientoPagado" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Descripcion"></label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Registrar Movimiento</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@model SistemaSeguridad.Models.UsuarioPregunta

@{
    ViewData["Title"] = "Ingresar Preguntas de Seguridad";
}

<h1> Ingresar Respuestas a Preguntas de Seguridad </h1>




<form asp-action="Crear" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label>1. ¿Nombre de tu primera mascota?</label>
        <input type="text" class="form-control" name="Respuesta1" required />
    </div>
    <div class="form-group">
        <label>2. ¿Lugar de nacimiento de tu madre?</label>
        <input type="text" class="form-control" name="Respuesta2" required />
    </div>
    <div class="form-group">
        <label>3. ¿Nombre del catedrático del curso de Análisis de Sistemas II?</label>
        <input type="text" class="form-control" name="Respuesta3" required />
    </div>
    <div class="form-group">
        <label>4. ¿Nombre de tu curso preferido?</label>
        <input type="text" class="form-control" name="Respuesta4" required />
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
